# =============================================================================
# Variables de entorno — copia este archivo a `.env` y ajústalo.
# Nunca subas `.env` al repositorio (está en .gitignore).
# =============================================================================

# --- Aplicación ---
APP_NAME=App Backend
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Servidor HTTP de la API ---
HOST=0.0.0.0
PORT=8000

# --- Base de datos ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Seguridad ---
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
MFA_CHALLENGE_EXPIRE_MINUTES=5

# Firma HMAC de webhooks entrantes (obligatorio en production, min 32 chars)
WEBHOOK_SECRET=dev-webhook-secret-change-me-please-32c

# En production: true (TLS en el reverse proxy + X-Forwarded-Proto=https)
FORCE_HTTPS=false

RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_SECONDS=60

# --- CORS estricto ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Webhook-Signature

# --- Production checklist ---
# APP_ENV=production
# DEBUG=false          # se fuerza a false automáticamente
# FORCE_HTTPS=true
# SECRET_KEY=<random >=32 chars>
# WEBHOOK_SECRET=<random >=32 chars>
# CORS_ORIGINS=https://tu-frontend.com
