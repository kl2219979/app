# Keep the Docker build context small (api image).
# Without this, COPY . . ships .venv (~180MB+) every --build.

.git
.github
.venv
venv
__pycache__
**/__pycache__
*.py[cod]
*$py.class
.pytest_cache
.ruff_cache
.mypy_cache
.coverage
htmlcov
.cursor
*.md
!README.md
.env
.env.*
!.env.example
docs
postman
.vscode
.idea
*.log
.DS_Store
